{
  "Settings": {
    "UseHome": true,
    "RemoteSourceRefreshIntervalMinutes": 15,
    "EmulatorPath": "./runmame",
    "PreCacheRemoteSources": true,
    "LogCleanupIntervalMinutes": 15,
    "MaxLogEntries": 10000,
    "HeadlessSource": "NABU Launcher",
    "StartEmulatorInHeadlessMode": true,
    "EnableJavaScript": false,
    "PackageRefreshIntervalMinutes": 5,
    "Sources": [],
    "Protocols": [],
    "TCP": [
      {
        "SendBufferSize": 8,
        "ReceiveBufferSize": 8,
        "Source": "NABU Launcher",
        "Port": "5816",
        "Enabled": true,
        "Timeout": "00:00:01",
        "StorageRedirects": {},
        "EnableCopyOnSymLinkWrite": true
      }
    ],
    "Serial": []
  },
  "Packages": {
    "Sources": [
      {
        "Name": "Local",
        "Path": "https://raw.githubusercontent.com/NABUligans/NAPA/main/repository/1R3/repo.json"
      }
    ]
  },
  "Headlines": {
    "Feeds": [
      {
        "Name": "Youtube",
        "Url": "https://rss.app/feeds/bQaXJIWLsRFoLQ76.xml"
      },
      {
        "Name": "NabuNetwork",
        "Url": "https://www.nabunetwork.com/feed/"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System.Net.*": "Warning",
      "Microsoft.*": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "variables": {
      "nns_layout": "${level:lowercase=true:truncate=4:when=level==LogLevel.Info or level==LogLevel.Warn}${when:when=level==LogLevel.Error:inner=fail}${when:when=level==LogLevel.Fatal:inner=crit}${when:when=level==LogLevel.Debug:inner=dbug}${when:when=level==LogLevel.Trace:inner=trce}: [${date:format=yyyy-MM-dd} ${time}] ${logger:shortName=True}: ${message}${onexception:inner=${newline}${exception:format=tostring}}"
    },
    "extensions": [
      { "assembly": "NLog.Extensions.Logging" },
      { "assembly": "NLog.Web.AspNetCore" }
    ],
    "targets": {
      "async": true,
      "file": {
        "type": "File",
        "fileName": "",
        "archiveEvery": "Day",
        "maxArchiveFiles": 7,
        "maxArchiveDays": 7,
        "archiveNumbering": "Date",
        "layout": "${nns_layout}"
      },
      "colorconsole": {
        "type": "ColoredConsole",
        "layout": "${nns_layout}",
        "useDefaultRowHighlightingRules": false,
        "wordHighlightingRules": [
          {
            "regex": "^info",
            "foregroundColor": "DarkGreen"
          },
          {
            "regex": "^warn",
            "foregroundColor": "Yellow"
          },
          {
            "regex": "^fail",
            "foregroundColor": "Black",
            "backgroundColor": "Red"
          },
          {
            "regex": "^crit",
            "foregroundColor": "White",
            "backgroundColor": "Red"
          }
        ]
  
      }
    },
    "rules": [
      {
        "logger": "Microsoft.AspNetCore.*",
        "maxLevel": "Info",
        "final": true
      },
      {
        "logger": "System.Net.Http.**",
        "maxLevel": "Info",
        "final": true
      },
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "file, colorconsole"
      }
    ]
  },
  "AllowedHosts": "localhost;127.0.0.1;[::1]",
  "Urls": "http://localhost:5000"
}